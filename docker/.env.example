# =============================================================================
# Authentik - Configuración
# =============================================================================
# Copiar a .env y completar con valores reales. NO commitear .env.
# =============================================================================

# Tag de imagen (fijar versión para reproducibilidad)
AUTHENTIK_IMAGE=ghcr.io/goauthentik/server
AUTHENTIK_TAG=2026.5.2

# -----------------------------------------------------------------------------
# Autentik - Identidad
# -----------------------------------------------------------------------------
# URL pública del IdP. CRÍTICO: debe coincidir con el dominio real (HTTPS en prod).
# Ej: https://auth.tudominio.com
AUTHENTIK_HOST=

# Branding básico
AUTHENTIK_NAME=lyr-auth

# -----------------------------------------------------------------------------
# Secrets (generar con: openssl rand -base64 60)
# -----------------------------------------------------------------------------
AUTHENTIK_SECRET_KEY=

# -----------------------------------------------------------------------------
# PostgreSQL (reutilizamos el existente)
# -----------------------------------------------------------------------------
# Crear DB dedicada antes del primer arranque:
#   CREATE DATABASE authentik;
AUTHENTIK_POSTGRESQL__HOST=
AUTHENTIK_POSTGRESQL__PORT=5432
AUTHENTIK_POSTGRESQL__NAME=authentik
AUTHENTIK_POSTGRESQL__USER=
AUTHENTIK_POSTGRESQL__PASSWORD=

# Redis interno (definido en compose, no tocar)
AUTHENTIK_REDIS__HOST=redis
AUTHENTIK_REDIS__PORT=6379

# -----------------------------------------------------------------------------
# Puertos expuestos (Dokploy los mapea; dejar default salvo necesidad real)
# -----------------------------------------------------------------------------
AUTHENTIK_PORT_HTTP=9000
AUTHENTIK_PORT_HTTPS=9443

# -----------------------------------------------------------------------------
# Email (opcional pero recomendado para recovery, invitaciones, alertas)
# -----------------------------------------------------------------------------
# SMTP_HOST=smtp.tudominio.com
# SMTP_PORT=587
# SMTP_USERNAME=lyr-auth@tudominio.com
# SMTP_PASSWORD=
# SMTP_USE_TLS=true
# SMTP_FROM=lyr-auth@tudominio.com

# -----------------------------------------------------------------------------
# Error reporting (desactivado por default; activar si querés contribuir)
# -----------------------------------------------------------------------------
AUTHENTIK_ERROR_REPORTING__ENABLED=false
